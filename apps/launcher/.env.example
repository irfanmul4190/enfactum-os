# Choose one provider: firebase or supabase
VITE_AUTH_PROVIDER=firebase

# Launcher app URLs
# Market-Grammer is active now; the rest are placeholders until their apps are ready.
VITE_MARKET_GRAMMER_URL=http://localhost:5174
VITE_LAUNCHER_ENFORGE_URL=
VITE_LAUNCHER_PROFIT_NAVIGATOR_URL=
VITE_LAUNCHER_INVOICING_HUB_URL=
VITE_LAUNCHER_GROWTH_STUDIO_URL=
VITE_LAUNCHER_MDF_CENTRAL_URL=
VITE_LAUNCHER_ANALYTICS_COMMAND_URL=

# Local dev ports
# Launcher: http://localhost:5173
# Market-Grammer: http://localhost:5174

# Firebase web app config (required when VITE_AUTH_PROVIDER=firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Supabase config (required when VITE_AUTH_PROVIDER=supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
